{
  "name": "devops-monorepo",
  "version": "1.0.50",
  "workspaces": [
    "api-gateway",
    "order-service",
    "product-service",
    "user-service"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:gateway": "bun --cwd api-gateway run dev",
    "dev:user": "bun --cwd user-service run dev",
    "dev:order": "bun --cwd order-service run dev",
    "dev:product": "bun --cwd product-service run dev",
    "dev:all": "pm2 start ecosystem.config.ts"
  },
  "devDependencies": {
    "bun-types": "latest",
    "pm2": "^6.0.14"
  }
}

